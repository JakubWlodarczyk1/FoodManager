@using FoodManager.Application.Resources.Localizations
@using Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = Lang.AdminPanel;
}

@await Html.PartialAsync("_Breadcrumbs", new List<BreadcrumbItemViewModel>
{
    new() { Title = Lang.HomePage, Url = Url.Action("Index", "Home") },
    new() { Title = Lang.AdminPanel }
})

<div class="container py-4">
    <div class="mb-4">
        <h1 class="mb-2">@Lang.AdminPanel</h1>
        <p class="text-muted mb-0">@Lang.AdminPanelDescription</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="card-title h5">@Lang.Users</div>
                    <p class="card-text text-muted">
                        @Lang.AdminUsersDescription
                    </p>
                    <div class="mt-auto">
                        <a asp-action="Users" class="btn btn-primary">@Lang.Users</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="card-title h5">@Lang.Products</div>
                    <p class="card-text text-muted">
                        @Lang.AdminProductsDescription
                    </p>
                    <div class="mt-auto">
                        <a asp-action="Products" class="btn btn-primary">@Lang.Products</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>